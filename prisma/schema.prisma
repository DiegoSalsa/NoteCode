generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@map("clients")
}

model Project {
  id            String               @id @default(uuid())
  name          String
  description   String?
  status        String               @default("En progreso")
  clientId      String               @map("client_id")
  client        Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  statusLogs    ProjectStatusLog[]
  requirements  ProjectRequirement[]
  techs         ProjectTech[]
  credentials   ProjectCredential[]
  notes         ProjectNote[]

  @@map("projects")
}

model ProjectStatusLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("project_status_logs")
}

model ProjectRequirement {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  category    String  @default("Funcional")
  priority    String  @default("Media")
  completed   Boolean @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("project_requirements")
}

model ProjectTech {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  category  String   @default("Frontend")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("project_techs")
}

model ProjectCredential {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  service   String
  username  String
  password  String
  url       String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("project_credentials")
}

model ProjectNote {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("project_notes")
}

model Credential {
  id        String   @id @default(uuid())
  title     String
  service   String
  username  String
  password  String
  url       String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("credentials")
}

model Invoice {
  id        String    @id @default(uuid())
  number    String
  client    String
  amount    Float
  status    String    @default("Pendiente")
  dueDate   DateTime  @map("due_date")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("invoices")
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("")
  folder    String   @default("General")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notes")
}