generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id        String    @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@index([name])
  @@map("clients")
}

model Project {
  id           String   @id @default(uuid())
  name         String
  description  String?
  status       String   @default("En progreso")
  agreedAmount Float    @default(0) @map("agreed_amount")
  clientId     String   @map("client_id")
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  statusLogs       ProjectStatusLog[]
  requirements     ProjectRequirement[]
  techs            ProjectTech[]
  vaultCredentials Credential[]
  credentials      ProjectCredential[]
  notes            ProjectNote[]
  invoice          Invoice?

  @@index([clientId])
  @@index([status])
  @@index([updatedAt])
  @@index([status, updatedAt])
  @@map("projects")
}

model ProjectStatusLog {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("project_status_logs")
}

model ProjectRequirement {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  category    String   @default("Funcional")
  priority    String   @default("Media")
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([completed])
  @@index([priority])
  @@map("project_requirements")
}

model ProjectTech {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  category  String   @default("Frontend")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([category])
  @@map("project_techs")
}

model ProjectCredential {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  service   String
  username  String
  password  String
  url       String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([service])
  @@map("project_credentials")
}

model ProjectNote {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([updatedAt])
  @@map("project_notes")
}

model Credential {
  id         String     @id @default(uuid())
  projectId  String?    @map("project_id")
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  username   String
  secretData String     @map("secret_data")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  auditLogs  AuditLog[]

  @@index([projectId])
  @@index([updatedAt])
  @@map("credentials")
}

model Document {
  id        String   @id @default(uuid())
  name      String
  category  String   @default("General")
  mimeType  String   @map("mime_type")
  size      Int
  fileData  Bytes    @map("file_data")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([updatedAt])
  @@index([name])
  @@map("documents")
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  action       String
  credentialId String?     @map("credential_id")
  credential   Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([credentialId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserProfile {
  id              String           @id @default(uuid())
  userId          String           @unique @map("user_id")
  email           String           @unique
  displayName     String           @map("display_name")
  passwordHash    String?          @map("password_hash")
  passwordChangedAt DateTime?      @map("password_changed_at")
  age             Int?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  personalSecrets PersonalSecret[]
  authTokens      AuthToken[]
  passkeys        Passkey[]
  emailMessages   EmailMessage[]

  @@index([email])
  @@map("user_profiles")
}

model EmailMessage {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  to        String
  subject   String
  body      String
  status    String      @default("draft")
  source    String      @default("manual")
  resendId  String?     @map("resend_id")
  error     String?
  sentAt    DateTime?   @map("sent_at")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([userId, status, updatedAt])
  @@index([sentAt])
  @@map("email_messages")
}

model Passkey {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  user         UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  credentialId String      @unique @map("credential_id")
  publicKey    Bytes       @map("public_key")
  counter      Int         @default(0)
  transports   String[]    @default([])
  deviceType   String      @map("device_type")
  backedUp     Boolean     @default(false) @map("backed_up")
  createdAt    DateTime    @default(now()) @map("created_at")
  lastUsedAt   DateTime?   @map("last_used_at")

  @@index([userId])
  @@map("passkeys")
}

model AuthToken {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  tokenHash String      @unique @map("token_hash")
  purpose   String
  expiresAt DateTime    @map("expires_at")
  usedAt    DateTime?   @map("used_at")
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([userId, purpose, usedAt, expiresAt])
  @@map("auth_tokens")
}

model PersonalSecret {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  user       UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  name       String
  username   String?
  secretData String      @map("secret_data")
  notes      String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([userId])
  @@index([updatedAt])
  @@map("personal_secrets")
}

model Invoice {
  id        String    @id @default(uuid())
  projectId String?   @unique @map("project_id")
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  number    String
  client    String
  amount    Float
  status    String    @default("Pendiente")
  dueDate   DateTime  @map("due_date")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@index([dueDate])
  @@index([client])
  @@map("invoices")
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String   @default("")
  folder    String   @default("General")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([folder])
  @@index([updatedAt])
  @@index([createdAt])
  @@map("notes")
}
